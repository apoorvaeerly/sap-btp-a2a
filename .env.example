# ==============================================================================
# SAP BTP A2A — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env to Git — it is listed in .gitignore.
#
# How to get SAP AI Core credentials:
#   1. BTP Cockpit → Services → Instances and Subscriptions
#   2. Click > on your AI Core instance (plan: extended)
#   3. Service Keys tab → view or download the JSON
#   4. Extract the fields listed below
# ==============================================================================


# ==============================================================================
# SAP AI Core — Required for all agents
# ==============================================================================

# From service key JSON → uaa.clientid
AI_CORE_CLIENT_ID=

# From service key JSON → uaa.clientsecret
AI_CORE_CLIENT_SECRET=

# From service key JSON → uaa.url  +  /oauth/token appended at the end
# Example: https://your-subdomain.authentication.us10.hana.ondemand.com/oauth/token
AI_CORE_AUTH_URL=

# From service key JSON → serviceurls.AI_API_URL
# Example: https://api.ai.prod.us-east-1.aws.ml.hana.ondemand.com
AI_CORE_API_URL=

# Resource group — leave as "default" unless you have a custom group
AI_CORE_RESOURCE_GROUP=default

# Model name — must match a RUNNING deployment in AI Launchpad
# Check: AI Launchpad → ML Operations → Deployments
SAP_MODEL_NAME=gpt-4.1

# Deployment ID — used by test_completion.py only
# Find in: AI Launchpad → ML Operations → Deployments → copy the ID
AI_CORE_DEPLOYMENT_ID=


# ==============================================================================
# Eerly Studio Agent (sandbox — SAP Expert proxy)
# ==============================================================================

# Provider switch — controls which agent the bridge adapter calls
#   sandbox → local LangGraph agent at AGENT_BASE_URL (current setup)
#   eerly   → real Eerly AI Studio API (future — when Accely provides credentials)
AGENT_PROVIDER=sandbox

# Public URL of the Eerly Studio agent
#   sandbox: ngrok forwarding URL (update every time ngrok restarts)
#   production: real Eerly AI Studio base URL from Accely
# Example: https://nonpredictable-example.ngrok-free.dev
AGENT_BASE_URL=

# API key for Eerly Studio
#   sandbox: leave empty — no auth needed for local agent
#   production: API key provided by Accely
AGENT_API_KEY=

# Request timeout in seconds
# Set to 60 — SAP AI Core GPT-4.1 can take 20-40s on complex queries
AGENT_TIMEOUT=60


# ==============================================================================
# Joule Persona Agent (SAP Joule stand-in)
# ==============================================================================

# URL of the Joule agent
#   persona stand-in: http://localhost:8001 (current setup)
#   real SF Joule:    CF bridge app URL after deployment
#   real S/4H Joule:  SAP Build skill endpoint URL
JOULE_BASE_URL=http://localhost:8001

# API key for Joule
#   persona stand-in: leave empty
#   real Joule:       credentials provided by SF/BTP admin
JOULE_API_KEY=


# ==============================================================================
# CF Bridge App (server.js — Joule → Eerly direction, production only)
# ==============================================================================
# These are set via: cf set-env eerly-bridge EERLY_API_URL "..."
# Do NOT put real values here — set them directly in CF environment.
# Listed here for documentation purposes only.

# Base URL of real Eerly AI Studio API (confirm with Accely)
# EERLY_API_URL=https://api.eerly.ai

# API key for Eerly AI Studio (confirm with Accely)
# EERLY_API_KEY=


# ==============================================================================
# Langfuse Tracing (optional)
# ==============================================================================
# If provided, LLM calls are traced in Langfuse for observability.
# Leave empty to disable tracing.
# Sign up at: https://cloud.langfuse.com

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

